# .gitignore for macOS Hardening Project

# macOS System Files
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Thumbnails and Metadata
.Spotlight-V100
.Trashes

# Dependencies
node_modules/

# Local audit working files
audit/

# Sensitive Local Data (Don't leak your own logs/backups)
*.log
*.swp
.env
local_audit_results.txt

# Terminal / Shell History (if you store scripts locally)
.bash_history
.zsh_history

# Recovery runtime artifacts (003-compaction-recovery)
.claude/recovery-marker.json
.claude/recovery-interrupted-task.json
.claude/recovery-audit-complete
.claude/recovery-logs/


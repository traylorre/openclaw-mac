# .gitignore for macOS Hardening Project

# macOS System Files
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Thumbnails and Metadata
.Spotlight-V100
.Trashes

# Dependencies
node_modules/

# Local audit working files
audit/
openclaw-audit.json

# Sensitive Local Data (Don't leak your own logs/backups)
*.log
*.swp
.env
local_audit_results.txt
scripts/templates/secrets/

# Terminal / Shell History (if you store scripts locally)
.bash_history
.zsh_history

# Recovery runtime artifacts (003-compaction-recovery)
.claude/recovery-marker.json
.claude/recovery-interrupted-task.json
.claude/recovery-audit-complete
.claude/recovery-logs/

# Claude Code local state (machine-specific, contains session permissions)
.claude/settings.local.json

# Claude Code memories (stored in private dotfiles repo)
.claude/memory/
.claude/projects/*/memory/

# Context carryover files (session state, never committed)
**/CONTEXT-CARRYOVER-*.md

# Carryover runtime artifacts (002-context-auto-rotation)
.claude/carryover-pending
.claude/carryover-pending.claimed
.claude/carryover-clear-needed
.claude/sessionstart-canary.last
*.loaded
